# =============================================================================
# TRADOVATE API CREDENTIALS
# =============================================================================
# Get these from Tradovate: Settings → API Keys → Generate API Key

TRADOVATE_USERNAME=your_username
TRADOVATE_PASSWORD=your_password
TRADOVATE_CID=12345
TRADOVATE_SECRET=your_secret_key

# Environment: "demo" for paper trading, "live" for real trading
# ALWAYS start with "demo" to test your bot!
TRADOVATE_ENV=demo

# =============================================================================
# TRADERSPOST WEBHOOK
# =============================================================================
# Get this from TradersPost: Strategies → Create Strategy → Copy Webhook URL
# Format: https://webhooks.traderspost.io/trading/webhook/{uuid}/{password}

TRADERSPOST_WEBHOOK_URL=https://webhooks.traderspost.io/trading/webhook/YOUR_UUID/YOUR_PASSWORD

# =============================================================================
# BOT CONFIGURATION
# =============================================================================

# Contract symbol (update when rolling to next contract)
# NQ Quarterly codes: H=Mar, M=Jun, U=Sep, Z=Dec
# Example: NQH5 = NQ March 2025
BOT_TICKER=NQH5

# Paper mode: "true" for simulation, "false" for live trading
# Set to "true" until you're confident in the bot's performance!
BOT_PAPER_MODE=true

# Risk Management
BOT_CONTRACTS=2
BOT_DAILY_MAX_LOSS=500

# =============================================================================
# NOTES
# =============================================================================
#
# 1. NEVER commit this file to git! It contains sensitive credentials.
#    The .gitignore file should already exclude it.
#
# 2. To use this file:
#    - Copy to your bot directory: cp config_example.env .env
#    - Edit .env with your actual credentials
#    - Bot will load from .env automatically
#
# 3. Credential security:
#    - Use unique API keys for this bot
#    - Rotate credentials periodically
#    - Consider using a secrets manager in production
#
# 4. TradersPost setup:
#    - Create strategy in TradersPost dashboard
#    - Connect your Tradovate broker
#    - Copy the full webhook URL (includes uuid and password)
#
# 5. Contract rollover:
#    - NQ futures expire quarterly (3rd Friday)
#    - Roll 1-2 weeks before expiration
#    - Update BOT_TICKER when rolling
#
